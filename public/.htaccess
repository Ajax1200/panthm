# ── HTTP Headers & Security Policies ──────────────────────────────────────────
<IfModule mod_headers.c>
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://va.me https://wa.me; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://api.panthm.com https://api.indexnow.org; frame-src 'self' https://www.youtube.com https://player.vimeo.com https://maps.google.com https://www.google.com; object-src 'none'; upgrade-insecure-requests;"
  Header set X-Frame-Options "DENY"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), interest-cohort=()"
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header set X-XSS-Protection "1; mode=block"

  # Browser Caching for static assets (1 year)
  <FilesMatch "\.(jpg|jpeg|gif|png|svg|woff|woff2|eot|ttf|css|js|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Cache Bypass for dynamic indexing files
  <FilesMatch "^(sitemap\.xml|rss\.xml|llms\.txt|llms-full\.txt)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Explicit MIME Types for Static SEO Files ────────────────────────────────
<IfModule mod_mime.c>
  AddType application/xml .xml
  AddType text/plain .txt
  AddType application/json .json
  AddType application/rss+xml .rss
</IfModule>

# ── URL Rewrite Rules ────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ── Redirect www to non-www (SEO best practice) ─────────────────────────────
  RewriteCond %{HTTP_HOST} ^www\.(.+) [NC]
  RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

  # ── Critical: Serve all real static files directly — NEVER fall through to SPA ──
  # This fixes sitemap.xml, robots.txt, llms.txt, rss.xml returning index.html
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # Also serve real directories directly
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ── LLM Feeds Redirect ──────────────────────────────────────────────────────
  RewriteRule ^llms\.txt$ llms-full.txt [L]
  RewriteRule ^\.well-known/llms\.txt$ llms-full.txt [L]

  # ── LLM & AI Bot Dynamic RAG Cloaking ────────────────────────────────────────
  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^$ https://api.panthm.com/api/bot-handler?path=home [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^about-us/?$ https://api.panthm.com/api/bot-handler?path=about-us [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^services/?$ https://api.panthm.com/api/bot-handler?path=services [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^services/([^/]+)/?$ https://api.panthm.com/api/bot-handler?path=services&name=$1 [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^contact/?$ https://api.panthm.com/api/bot-handler?path=contact [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^portfolio/?$ https://api.panthm.com/api/bot-handler?path=portfolio [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^blogs/?$ https://api.panthm.com/api/bot-handler?path=blogs [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^blogs/([^/]+)/?$ https://api.panthm.com/api/bot-handler?path=blogs&slug=$1 [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^solutions/?$ https://api.panthm.com/api/bot-handler?path=solutions [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^solutions/([^/]+)/([^/]+)/([^/]+)/([^/]+)/?$ https://api.panthm.com/api/bot-handler?path=solutions&locale=$1&service=$2&industry=$3&location=$4 [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^solutions/([^/]+)/([^/]+)/([^/]+)/?$ https://api.panthm.com/api/bot-handler?path=solutions&service=$1&industry=$2&location=$3 [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^web-development/?$ https://api.panthm.com/api/bot-handler?path=solutions&service=web-development&industry=enterprise&location=global [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^app-development/?$ https://api.panthm.com/api/bot-handler?path=solutions&service=app-development&industry=enterprise&location=global [R=307,L]

  RewriteCond %{HTTP_USER_AGENT} (gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner) [NC]
  RewriteRule ^ai-calling-agency/?$ https://api.panthm.com/api/bot-handler?path=solutions&service=ai-calling-agency&industry=enterprise&location=global [R=307,L]

  # ── Google Search Verification Route ─────────────────────────────────────────
  RewriteRule ^google21a602606c3c9141$ google21a602606c3c9141.html [L]

  # ── Single Page App (SPA) Routing (Failsafe fallback) ───────────────────────
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-l
  RewriteRule . /index.html [L]
</IfModule>

# Enable Gzip Compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>
