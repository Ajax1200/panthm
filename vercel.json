{
  "cleanUrls": true,
  "routes": [
    {
      "src": "^/$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner|GPTBot|ChatGPT|OpenAI|Anthropic|Claude|Perplexity|Cohere|Google-Extended|Vertex|AI-Overviews|SearchGPT|Search-Partner).*"
        }
      ],
      "dest": "/llms.txt"
    },
    {
      "src": "^/(about|services|contact|portfolio|blogs|solutions|blogs/.*|web-development|app-development|ai-calling-agency)$",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(gptbot|chatgpt|openai|anthropic|claude|perplexity|cohere|google-extended|vertex|ai-overviews|searchgpt|search-partner|GPTBot|ChatGPT|OpenAI|Anthropic|Claude|Perplexity|Cohere|Google-Extended|Vertex|AI-Overviews|SearchGPT|Search-Partner).*"
        }
      ],
      "dest": "/PCA_Whitepaper.md"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
